# Copy this file to .env and fill in real values.
# .env is already in .gitignore — never commit real secrets.

PORT=3000
APP_URL=http://localhost:3000
SESSION_SECRET=change-this-to-a-long-random-string

# ---- Database (Supabase Postgres) ----
# Supabase Dashboard > your project > Project Settings > Database >
# Connection Pooling > Connection string (URI). Use the POOLER string
# (port 6543), not the direct connection (port 5432) — see README.
DATABASE_URL=

# ---- Clerk (real sign-in / sign-up) ----
# Get both from https://dashboard.clerk.com > your app > API Keys
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ---- Stripe (dues collection) — optional, app runs fine without it ----
# Get from https://dashboard.stripe.com/apikeys (use TEST keys while developing)
STRIPE_SECRET_KEY=
# From `stripe listen --forward-to localhost:3000/api/payments/webhook`
STRIPE_WEBHOOK_SECRET=

# ---- Email (Resend) — optional, but reminders/announcements only show up
# in-app without it, which defeats the point. Get a free key at resend.com.
RESEND_API_KEY=
# Works with zero setup using their resend.dev test sender, but that can only
# email the address your Resend account itself is registered with. Verify
# your own domain in the Resend dashboard before other people's email needs
# to actually arrive, then set this to something like "Club OS <hello@yourdomain.com>".
EMAIL_FROM=Club OS <onboarding@resend.dev>

# ---- Feedback ----
# Where "Send Feedback" in the app gets emailed to. Leave blank and it just
# logs to the server console instead of erroring.
FEEDBACK_EMAIL=
